{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Rustisaur",
    "scopeName": "source.rex",
    "fileTypes": ["rex"],
    "patterns": [
      { "include": "#comments" },
      { "include": "#strings" },
      { "include": "#keywords" },
      { "include": "#functions" },
      { "include": "#numbers" }
    ],
    "repository": {
      "comments": {
        "patterns": [
          {
            "name": "comment.line.double-dash.rex",
            "match": "--.*$"
          }
        ]
      },
      "strings": {
        "patterns": [
          {
            "name": "string.quoted.double.rex",
            "begin": "\"",
            "end": "\"",
            "patterns": [
              {
                "name": "constant.character.escape.rex",
                "match": "\\\\."
              }
            ]
          }
        ]
      },
      "keywords": {
        "patterns": [
          {
            "name": "keyword.control.rex",
            "match": "\\b(if|then|else|elseif|end|while|do|for|in|repeat|until|function|local|return|break|and|or|not)\\b"
          },
          {
            "name": "keyword.other.rex",
            "match": "\\b(rex\\.(print|input|fs|string|table|math|json|os))\\b"
          }
        ]
      },
      "functions": {
        "patterns": [
          {
            "name": "entity.name.function.rex",
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
          }
        ]
      },
      "numbers": {
        "patterns": [
          {
            "name": "constant.numeric.rex",
            "match": "\\b\\d+(\\.\\d+)?\\b"
          }
        ]
      }
    }
  }